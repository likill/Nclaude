# NaohuaClaude 环境配置模板
# 用法：cp .env.example .env，然后按需修改

# ── Core Daemon ───────────────────────────────────────────────
NAOHUA_HOST=127.0.0.1
NAOHUA_PORT=7437

# ── Logging ───────────────────────────────────────────────────
NAOHUA_LOG_LEVEL=INFO
# 留空则仅输出 stderr，不写文件
NAOHUA_LOG_FILE=~/.naohua/logs/core.log
# text（人工可读键值对）或 json（结构化，适合日志聚合）
NAOHUA_LOG_FORMAT=text

# ── Config File ───────────────────────────────────────────────
# NAOHUA_CONFIG=~/.naohua/config.toml

# ── LLM（S1 阶段启用）────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# NAOHUA_LLM_DEFAULT_MODEL=claude-sonnet-4-6
# NAOHUA_MAX_STEPS=20
